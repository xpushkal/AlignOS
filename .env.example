# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token        # only needed for Socket Mode

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key  # server-side only, keep secret

# --- LLM provider ---
ANTHROPIC_API_KEY=your-anthropic-key
LLM_MODEL=claude-opus-4-8

# --- App ---
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# --- Real-Time Search (optional; falls back to channel history if unset) ---
SLACK_RTS_ENABLED=false
