# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token        # only needed for Socket Mode

# --- Neon PostgreSQL ---
# Connection string from the Neon dashboard (use the pooled endpoint).
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/alignos?sslmode=require

# --- LLM provider (OpenRouter — OpenAI-compatible API) ---
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # override if needed

# --- App ---
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# --- Security / rate limiting ---
MAX_INPUT_CHARS=4000
RATE_LIMIT_MAX_CALLS=20
RATE_LIMIT_WINDOW_SECONDS=60
# AGENT_API_TOKEN=                 # if set, /agent/* requires header X-AlignOS-Token

# --- Concurrency / scale ---
MAX_CONCURRENCY=8                  # max blocking (DB/LLM) tasks running at once
DB_POOL_MAX_SIZE=10                # Neon connection pool size (>= MAX_CONCURRENCY)

# --- Shared state (Redis) — required to run multiple instances ---
# REDIS_URL=redis://localhost:6379/0   # unset = in-process state (single instance)
CACHE_TTL_SECONDS=300

# --- Real-Time Search (optional; falls back to channel history if unset) ---
SLACK_RTS_ENABLED=false
