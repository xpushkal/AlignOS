# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token        # only needed for Socket Mode

# --- Neon PostgreSQL ---
# Connection string from the Neon dashboard (use the pooled endpoint).
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/alignos?sslmode=require

# --- LLM provider (OpenRouter — OpenAI-compatible API) ---
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # override if needed

# --- App ---
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# --- Real-Time Search (optional; falls back to channel history if unset) ---
SLACK_RTS_ENABLED=false
