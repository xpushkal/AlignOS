# Slack App configuration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
# Socket mode flag (True/False). If True, app connects to Slack using Socket Mode.
SLACK_SOCKET_MODE=True

# OpenRouter Configuration for LLM Layer
OPENROUTER_API_KEY=your-openrouter-api-key
# Selected model on OpenRouter (default: google/gemini-2.5-flash)
OPENROUTER_MODEL=google/gemini-2.5-flash

# SQLite Database configurations
DB_PATH=alignos.db
